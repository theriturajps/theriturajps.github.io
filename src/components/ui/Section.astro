---
/** Section component with label and contents */
const { label } = Astro.props;
---
<section class="section">
  <h4 class="label">{label}</h4>
  <slot />
</section>
<style>
  .section {
    padding-bottom: var(--space-md-16);
    font-size: var(--font-sm-12);
    font-weight: 400;
    color: var(--dimmed);
  }

  .label {
    margin: 0 0 var(--space-sm-8);
    text-transform: uppercase;
    font-size: var(--font-sm-14);
    font-weight: 700;
    letter-spacing: 0.01rem;
    color: var(--white);
  }
</style>